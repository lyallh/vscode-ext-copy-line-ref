{
  "name": "copy-line-ref",
  "displayName": "Copy Line Reference",
  "description": "Copy a filename:line reference (e.g. main.ts:10-21) to the clipboard for use as LLM code context.",
  "version": "0.0.1",
  "publisher": "lyallh",
  "repository": {
    "type": "git",
    "url": "https://github.com/lyallh/vscode-ext-copy-line-ref.git"
  },
  "homepage": "https://github.com/lyallh/vscode-ext-copy-line-ref",
  "packageManager": "pnpm@10.12.4",
  "bugs": {
    "url": "https://github.com/lyallh/vscode-ext-copy-line-ref/issues"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copyLineRef.copyReference",
        "title": "Copy Line Reference",
        "category": "Editor"
      },
      {
        "command": "copyLineRef.copyReferenceWithCode",
        "title": "Copy Line Reference with Code",
        "category": "Editor"
      },
      {
        "command": "copyLineRef.showHistory",
        "title": "Show Copy History",
        "category": "Editor"
      },
      {
        "command": "copyLineRef.copyFileReference",
        "title": "Copy File Reference",
        "category": "Editor"
      },
      {
        "command": "copyLineRef.recopyLast",
        "title": "Re-copy Last Reference",
        "category": "Editor"
      }
    ],
    "keybindings": [
      {
        "command": "copyLineRef.copyReference",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorTextFocus"
      },
      {
        "command": "copyLineRef.copyReferenceWithCode",
        "key": "ctrl+alt+shift+c",
        "mac": "cmd+alt+shift+c",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "copyLineRef.copyReference",
          "when": "editorTextFocus",
          "group": "9_cutcopypaste"
        },
        {
          "command": "copyLineRef.copyReferenceWithCode",
          "when": "editorTextFocus",
          "group": "9_cutcopypaste"
        }
      ]
    },
    "configuration": {
      "title": "Copy Line Reference",
      "properties": {
        "copyLineRef.format": {
          "type": "string",
          "enum": [
            "simple",
            "github",
            "markdown-link"
          ],
          "enumDescriptions": [
            "src/main.ts:10-21",
            "https://github.com/org/repo/blob/<commit>/src/main.ts#L10-L21  (prefers origin, falls back to simple if not a GitHub repo)",
            "[src/main.ts:10-21](./src/main.ts)"
          ],
          "default": "simple",
          "description": "Output format for copied line references."
        },
        "copyLineRef.includeSymbol": {
          "type": "boolean",
          "default": false,
          "description": "Append the enclosing symbol name to the references, e.g. src/auth.ts:45::handleLogin. Ignored for GitHub URLs."
        },
        "copyLineRef.contextLines": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Number of extra lines to include above and below the selection in the code block (Copy Line Reference with Code only). The reference always reflects the exact selection."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check": "pnpm run lint && npm run typecheck",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "node --require tsx/cjs --test src/test/utils.test.ts",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/node": "22.x",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "@vscode/vsce": "^3.0.0",
    "tsx": "^4.19.0"
  }
}
